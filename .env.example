# ── Required ──────────────────────────────────────────────────────────────────

# Base URL of your Strapi instance (no trailing slash)
STRAPI_URL=http://localhost:1337

# Strapi API token — Full Access or scoped to the content types you need
STRAPI_API_TOKEN=your-strapi-api-token-here

# ── Search Provider (optional — enables research_topic tool) ──────────────────

# Which search provider to use: tavily | brave | exa
SEARCH_PROVIDER=

# Tavily API key — required if SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# Brave Search API key — required if SEARCH_PROVIDER=brave
BRAVE_API_KEY=

# Exa API key — required if SEARCH_PROVIDER=exa
EXA_API_KEY=

# ── AI Provider (optional — enables generate_draft and create_content_from_research) ──

# Which AI provider to use: openai | anthropic | google | mistral | ollama
AI_PROVIDER=

# Model name for the selected provider, e.g. claude-sonnet-4-6 | gpt-4o | gemini-1.5-pro
AI_MODEL=

# Anthropic API key — required if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# OpenAI API key — required if AI_PROVIDER=openai
OPENAI_API_KEY=

# Google Generative AI API key — required if AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=

# Mistral API key — required if AI_PROVIDER=mistral
MISTRAL_API_KEY=

# Ollama base URL — required if AI_PROVIDER=ollama (no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
